{
	"name": "json-schema-compatibility-checker",
	"version": "1.0.6",
	"license": "MIT",
	"description": "A tool to check compatibility between two JSON Schemas.",
	"author": {
		"email": "arthurtinseau@live.fr",
		"url": "https://github.com/atinseau/json-schema-compatibility-checker",
		"name": "atinseau"
	},
	"type": "module",
	"main": "./dist/cjs/index.js",
	"module": "./dist/esm/index.js",
	"types": "./dist/esm/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/esm/index.d.ts",
				"default": "./dist/esm/index.js"
			},
			"require": {
				"types": "./dist/cjs/index.d.ts",
				"default": "./dist/cjs/index.js"
			}
		}
	},
	"sideEffects": false,
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"prepare": "lefthook install",
		"clean": "rm -rf dist",
		"build:esm": "swc src -d dist/esm --strip-leading-paths --config-file .swcrc.esm.json",
		"build:cjs": "swc src -d dist/cjs --strip-leading-paths --config-file .swcrc.cjs.json",
		"build:types:esm": "tsc --project tsconfig.build.json",
		"build:types:cjs": "tsc --project tsconfig.build.cjs.json",
		"build:swc": "bun --parallel build:esm build:cjs",
		"build:types": "bun --parallel build:types:esm build:types:cjs",
		"build": "bun run clean && bun --parallel build:swc build:types && bun run postbuild",
		"postbuild": "bun scripts/postbuild.ts",
		"prepublishOnly": "bun run build",
		"check-types": "tsc --noEmit",
		"check": "biome check --write --unsafe",
		"test": "bun test",
		"bench": "bun run benchmarks/run.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.3",
		"@types/bun": "latest",
		"lefthook": "2.1.1",
		"mitata": "1.0.34",
		"@swc/cli": "0.8.0",
		"@swc/core": "1.15.17"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"@x0k/json-schema-merge": "1.0.2",
		"class-validator": "0.14.3",
		"randexp": "0.5.3"
	}
}
